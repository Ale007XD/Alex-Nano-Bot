      "function": "get_allowed_users()",
      "source": "settings.ADMIN_IDS",
      "cached": false
    },
    "deploy": {
      "note": "COPY в образ, не volume mount — требует docker compose build при каждом изменении кода",
      "command": "docker compose build alex-nano-bot && docker compose up -d alex-nano-bot"
    }
  }
